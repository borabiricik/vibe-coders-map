{
  "name": "@vibe/api",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:local": "node ./scripts/test-local-pipeline.mjs",
    "type-check": "tsc --noEmit",
    "lint": "eslint src",
    "db:migrate:local": "wrangler d1 migrations apply vibe-coders-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply vibe-coders-db --remote"
  },
  "dependencies": {
    "h3-js": "^4.4.0",
    "hono": "^4",
    "ngeohash": "^0.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4",
    "@cloudflare/vitest-pool-workers": "^0.13",
    "@vibe/shared-types": "*",
    "typescript": "^5.7",
    "vitest": "^4.1.0",
    "wrangler": "^4.74.0"
  }
}
